<Window x:Class="SCAtlas.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SC Atlas"
        Height="780"
        Width="860"
        MinHeight="780"
        MinWidth="860"
        WindowStartupLocation="CenterScreen"
        Background="#FFF5F5F7">

    <Window.Resources>
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FF1F1F1F"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0,10,0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#FFD0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="16,0,16,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="#FFE7E7EA"/>
            <Setter Property="BorderBrush" Value="#FFCFCFD4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Bannière -->
        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#FFE2E2E2"
                BorderThickness="1"
                CornerRadius="10"
                Padding="6"
                Height="200">
            <Border CornerRadius="8"
                    ClipToBounds="True"
                    Background="#FF1F232A">
                <Image Source="/Assets/scatlas-banner.png"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
            </Border>
        </Border>

        <!-- Dossier Star Citizen -->
        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#FFE2E2E2"
                BorderThickness="1"
                CornerRadius="10"
                Padding="16">
            <StackPanel>
                <TextBlock Text="Dossier Star Citizen"
                           Style="{StaticResource SectionTitleStyle}"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="140"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="GamePathTextBox"
                             Grid.Column="0"
                             IsReadOnly="True"
                             Text="Aucun dossier sélectionné"/>

                    <Button x:Name="BrowseButton"
                            Grid.Column="2"
                            Content="Parcourir..."
                            Click="BrowseButton_Click"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Chemin cible -->
        <Border Grid.Row="4"
                Background="White"
                BorderBrush="#FFE2E2E2"
                BorderThickness="1"
                CornerRadius="10"
                Padding="16">
            <StackPanel>
                <TextBlock Text="Chemin cible"
                           Style="{StaticResource SectionTitleStyle}"/>

                <TextBox x:Name="TargetPathTextBox"
                         IsReadOnly="True"
                         Text="Aucun chemin cible déterminé"/>
            </StackPanel>
        </Border>

        <!-- Actions -->
        <Border Grid.Row="6"
                Background="White"
                BorderBrush="#FFE2E2E2"
                BorderThickness="1"
                CornerRadius="10"
                Padding="16">
            <StackPanel>
                <TextBlock Text="Actions"
                           Style="{StaticResource SectionTitleStyle}"/>

                <StackPanel Orientation="Horizontal">
                    <Button x:Name="InstallButton"
                            Content="Installer la traduction"
                            Width="220"
                            IsEnabled="False"
                            Click="InstallButton_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Statut -->
        <Border Grid.Row="8"
                Background="White"
                BorderBrush="#FFE2E2E2"
                BorderThickness="1"
                CornerRadius="10"
                Padding="16">
            <StackPanel>
                <TextBlock Text="Statut"
                           Style="{StaticResource SectionTitleStyle}"/>

                <Border Background="#FFF7F7F9"
                        BorderBrush="#FFD8D8DD"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12">
                    <TextBlock x:Name="StatusTextBlock"
                               Text="Prêt"
                               Foreground="#FF2A2A2A"
                               TextWrapping="Wrap"/>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Window>